# ─────────────────────────────────────────────────────────────────────────────
# Housing Agent secrets. Copy this file to `.env` and fill in the values.
# NEVER commit the real `.env` (it is gitignored).
# All *behavioural* settings live in config.yaml — this file is secrets only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Maps (commute times + geocoding) ─────────────────────────────────
# One key with BOTH "Routes API" and "Geocoding API" enabled in Google Cloud.
# (Enable the modern "Routes API" — NOT the legacy "Directions API".)
GOOGLE_MAPS_API_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
# Default transport is Resend (config.yaml -> email.transport: resend).
# Get an API key at https://resend.com. Without a verified domain, Resend's shared
# sender (onboarding@resend.dev) only delivers to the email you registered with.
RESEND_API_KEY=

# Alternative transport: SMTP via a Gmail app password (email.transport: smtp).
# Create one at https://myaccount.google.com/apppasswords (needs 2-Step Verification).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password
